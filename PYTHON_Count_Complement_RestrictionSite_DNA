Write a program that will print the complement of this sequence. (Not the reverse complement!)
dna = "ACTGATCGATTACGTATAGTATTTGCTATCATACATATATATCGATGCGTTCAT"
nuc_comp_dict = {"A": "T",
                "T": "A",
                "C": "G",
                "G": "C"}
comp = []
for base in dna:
    complement = nuc_comp_dict[base]
    comp.append(complement)

print("".join(comp))
