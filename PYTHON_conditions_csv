for line in open("data.csv"):
    fields = line.strip("\n").split(",")
    species = fields[0]
    seq = fields[1]
    gene = fields[2]
    xpr = fields[3]
    at_cont = (seq.count("a") + seq.count("t"))/ len(seq)
    
    if species.endswith("melanogaster") or species.endswith("simulans"):
        print(gene + " is found in D. melanogaster or D. simulans")
    
    if len(seq) >= 90 and len(seq) <= 110:
        print(gene + " is between 90 - 110 bases in length" )
    
    if at_cont >= 0.5 and int(xpr) >= 200:
        print(gene + " has an at content higher than 50% and an expression level over 200")

    if species != "Drosophila melanogaster" or species != "Drosophila simulans" and gene.startswith("k") or gene.startswith("h"):
        print(gene + " not found in D. melanogaster or D. simulans and begins with k or h")

    if at_cont < 0.45:
        print(gene + " : has LOW AT composition  " + str(at_cont))
    elif at_cont >= 0.45 and at_cont < 0.65:
        print(gene + " : has MODERATE AT composition " + str(at_cont))
    elif at_cont >= 0.65:
        print(gene + " : has HIGH AT composition  " + str(at_cont))

